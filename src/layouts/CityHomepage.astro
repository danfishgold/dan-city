---
import Default from "./Default.astro";
import CssCityTitle from "@/components/CssCityTitle/index.astro";
import { Image } from "astro:assets";
import type { Project } from "@/pages/_projects";
import type { Story } from "@/stories";

type Props = {
  title: string;
  subtitle: string;
  footer: string;
  lang: "en" | "he";
  projects: Project[];
  stories: Story[];
};
const { title, subtitle, projects, stories, lang, footer } = Astro.props;
---

<Default title={title} lang={lang}>
  <CssCityTitle title={title} subtitle={subtitle} />
  <main>
    {
      stories.length > 0 && (
        <div class="stories">
          {stories
            .sort((a, b) => b.date.getTime() - a.date.getTime())
            .map((story) => (
              <a class="story" href={`/stories/${story.id}`}>
                <div class="thumbnail">
                  <Image
                    src={story.thumbnail}
                    alt=""
                    widths={[50, 100, 200]}
                    loading="lazy"
                  />
                </div>
                {story.title}
              </a>
            ))}
        </div>
      )
    }
    <div class="blocks">
      {
        projects.map((project) => (
          <a
            href={project.url}
            class="project"
            data-columns={project.width}
            aria-disabled={!project.url}
          >
            <h2>{project.title}</h2>
            <p>{project.description}</p>
          </a>
        ))
      }
    </div>
  </main>
  <footer>
    <p>{footer}</p>
  </footer>
</Default>

<style>
  :root {
    --building-right-color: black;
    --building-top-color: white;
    --flat-building-color: hsl(166, 100%, 86%);
    --building-left-color: hsl(16, 100%, 66%);

    @supports (color: lch(0% 0 0)) {
      --flat-building-color: lch(95% 25 180);
      --building-left-color: lch(70% 70 45);
    }
  }

  .stories {
    display: flex;
    flex-direction: row;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 12px;
    margin-bottom: 32px;

    .story {
      width: 80px;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 4px;
      align-items: center;
      color: currentColor;
      text-decoration: none;
      font-size: 0.8rem;

      &:hover {
        text-decoration: underline;

        .thumbnail {
          border-color: #0004;
        }
      }

      &:focus-visible {
        text-decoration: underline;
        outline: none;

        .thumbnail {
          border-color: var(--title-color);
        }
      }

      .thumbnail {
        border: 4px solid #0002;
        border-radius: 1e5px;
        padding: 4px;

        img {
          display: block;
          height: 50px;
          width: auto;
          aspect-ratio: 1;
          border-radius: 1e5px;
        }
      }
    }
  }

  .blocks {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;

    .project {
      --shadow-depth: 5px;
      --shadow-scale: 1;
      text-decoration: none;
      hyphens: auto;
      color: black;
      background: var(--building-top-color);
      padding: 1rem;
      transition: transform 0.25s;
      position: relative;

      &[aria-disabled="true"] {
        opacity: 0.5;
      }

      @media (hover: hover) {
        &:hover {
          --shadow-scale: 2;
          transform: translate(
            calc(-1 * var(--shadow-depth)),
            var(--shadow-depth)
          );
        }
      }

      &:focus {
        outline: none;
        --shadow-scale: 2;
        transform: translate(
          calc(-1 * var(--shadow-depth)),
          var(--shadow-depth)
        );
      }

      &:focus-visible {
        background: hsl(350, 100%, 90%);
      }

      &:hover,
      &:focus-visible {
        h2 {
          text-decoration: underline;
        }
      }

      &:before {
        content: "";
        position: absolute;
        top: calc(-1 * var(--shadow-depth));
        height: var(--shadow-depth);
        left: 0;
        width: 100%;
        background: var(--title-color);
        transform: skewX(-45deg) scaleY(var(--shadow-scale));
        transform-origin: 0 100%;
        transition: transform 0.25s;
      }

      &:after {
        content: "";
        position: absolute;
        right: calc(-1 * var(--shadow-depth));
        width: var(--shadow-depth);
        top: 0;
        height: 100%;
        background: var(--building-right-color);
        transform: skewY(-45deg) scaleX(var(--shadow-scale));
        transform-origin: 0 0;
        transition: transform 0.25s;
      }

      &[data-columns="1"] {
        grid-column: span 1;
      }

      &[data-columns="2"] {
        grid-column: span 2;
      }

      &[data-columns="3"] {
        grid-column: span 3;
      }

      &[data-columns="4"] {
        grid-column: span 4;
      }

      &[data-columns="5"] {
        grid-column: span 5;
      }

      h2 {
        font-family: var(--title-font);
        margin-bottom: 0;
      }
    }
  }
</style>
